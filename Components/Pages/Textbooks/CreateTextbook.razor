@page "/create-textbook"

@using SomaShare.Data
@inject ApplicationDbContext Db
@inject NavigationManager Navigation

<h3>Create Textbook Listing</h3>

<EditForm Model="textbook" OnValidSubmit="CreateListing">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Title</label>
        <InputText class="form-control" @bind-Value="textbook.Title" />
    </div>

    <div class="mb-3">
        <label>Author</label>
        <InputText class="form-control" @bind-Value="textbook.Author" />
    </div>

    <div class="mb-3">
        <label>ISBN</label>
        <InputText class="form-control" @bind-Value="textbook.ISBN" />
    </div>

    <div class="mb-3">
        <label>Condition</label>
        <InputText class="form-control" @bind-Value="textbook.Condition" />
    </div>

    <div class="mb-3">
        <label>Campus</label>
        <InputText class="form-control" @bind-Value="textbook.Campus" />
    </div>

    <div class="mb-3">
        <label>Price</label>
        <InputNumber class="form-control" @bind-Value="textbook.Price" />
    </div>

    <button class="btn btn-primary">Create Listing</button>
</EditForm>

@code {
    private Textbook textbook = new();

    private async Task CreateListing()
    {
        Db.Textbooks.Add(textbook);
        await Db.SaveChangesAsync();

        Navigation.NavigateTo("/textbooks");
    }
}