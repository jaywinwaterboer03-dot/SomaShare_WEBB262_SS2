@page "/edit-textbook/{Id:int}"

@using SomaShare.Data
@inject ApplicationDbContext Db
@inject NavigationManager Navigation

<h3>Edit Textbook</h3>

@if (textbook == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="textbook" OnValidSubmit="UpdateBook">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Title</label>
            <InputText class="form-control" @bind-Value="textbook.Title" />
        </div>

        <div class="mb-3">
            <label>Author</label>
            <InputText class="form-control" @bind-Value="textbook.Author" />
        </div>

        <div class="mb-3">
            <label>ISBN</label>
            <InputText class="form-control" @bind-Value="textbook.ISBN" />
        </div>

        <div class="mb-3">
            <label>Course Code</label>
            <InputText class="form-control" @bind-Value="textbook.CourseCode" />
        </div>

        <div class="mb-3">
            <label>Campus</label>
            <InputText class="form-control" @bind-Value="textbook.Campus" />
        </div>

        <div class="mb-3">
            <label>Price</label>
            <InputNumber class="form-control" @bind-Value="textbook.Price" />
        </div>

        <button class="btn btn-success">Save Changes</button>
    </EditForm>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private Textbook? textbook;

    protected override async Task OnInitializedAsync()
    {
        textbook = await Db.Textbooks.FindAsync(Id);
    }

    private async Task UpdateBook()
    {
        await Db.SaveChangesAsync();

        Navigation.NavigateTo("/textbooks");
    }
}