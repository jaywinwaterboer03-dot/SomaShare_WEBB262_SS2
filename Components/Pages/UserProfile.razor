@page "/user-profile/{UserId}"
@rendermode InteractiveServer

@using SomaShare.Data
@inject UserManager<ApplicationUser> UserManager
@inject IReviewService ReviewService

<PageTitle>User Profile</PageTitle>

@if (user == null)
{
    <p>User not found.</p>
}
else
{
    <section class="profile-header">
        <h1>@user.FullName</h1>
        <div class="profile-info">
            <p><strong>Campus:</strong> @user.Campus</p>
            <p><strong>Preferred meetup campus:</strong> @user.PreferredMeetupCampus</p>
            <p><strong>Email:</strong> @user.Email</p>
            <p><strong>Phone:</strong> @(string.IsNullOrEmpty(user.PhoneNumber) ? "Not provided" : user.PhoneNumber)</p>
            <p><strong>Language:</strong> @user.PreferredLanguage</p>
            <p><strong>Trust Score:</strong> <span class="trust-score">@user.TrustScore ★</span></p>
            @if (!string.IsNullOrEmpty(user.Bio))
            {
                <div class="bio">
                    <h3>About</h3>
                    <p>@user.Bio</p>
                </div>
            }
        </div>
    </section>

    <section class="reviews-section">
        <h2>Reviews (@reviews.Count)</h2>
        @if (reviews.Count == 0)
        {
            <p class="text-muted">No reviews yet.</p>
        }
        else
        {
            @foreach (var review in reviews)
            {
                <div class="review-card">
                    <div class="review-header">
                        <strong>@review.Reviewer?.FullName</strong>
                        <span class="rating">@string.Join("", Enumerable.Range(0, review.Rating).Select(_ => "★"))@string.Join("", Enumerable.Range(0, 5 - review.Rating).Select(_ => "☆"))</span>
                    </div>
                    @if (!string.IsNullOrEmpty(review.Comment))
                    {
                        <p>@review.Comment</p>
                    }
                    <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                </div>
            }
        }
    </section>
}

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    private ApplicationUser? user;
    private List<Review> reviews = new();

    protected override async Task OnInitializedAsync()
    {
        user = await UserManager.FindByIdAsync(UserId);
        if (user != null)
        {
            reviews = await ReviewService.GetReviewsForUserAsync(UserId);
            reviews = reviews.Where(r => r.ReviewedUserId == UserId).OrderByDescending(r => r.CreatedAt).ToList();
        }
    }
}
